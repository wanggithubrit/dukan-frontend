{
  "expo": {
    "name": "DUKAN APP",
    "slug": "dukan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo_green.png",
    "scheme": "dukanapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/logo_green.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F5F5"
    },
    "android": {
      "package": "com.anonymous.dukan_app",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyFakeKeyForDev"
        }
      },
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo_green.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "backgroundColor": "#F5F5F5",
          "dark": {
            "image": "./assets/images/logo_green.png",
            "imageWidth": 160,
            "resizeMode": "contain",
            "backgroundColor": "#0F1F18"
          }
        }
      ],
      "expo-notifications",
      [
        "./plugins/react-native-google-mobile-ads.plugin.js",
        {
          "androidAppId": "ca-app-pub-9676497994699972~3190804579",
          "userTrackingUsageDescription": "This identifier will be used to deliver personalized ads to you."
        }
      ],
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "ios": {
      "bundleIdentifier": "com.anonymous.dukan-app"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "de72371e-b987-4c8b-a5c3-7853bb2c0d9f"
      }
    },
    "owner": "project-dukan"
  }
}
